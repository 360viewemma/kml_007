<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Mau_KML_AppSheet</name>
    
    <!-- Thẻ định nghĩa kiểu dáng (Style Definition) -->
    <Style id="DinhDang_VungDo">
      <LineStyle>
        <!-- Màu viền: Đỏ, độ dày: 3px -->
        <color>ff0000ff</color> 
        <width>3</width>
      </LineStyle>
      <PolyStyle>
        <!-- Màu nền: Đỏ, độ mờ: 50% -->
        <color>800000ff</color> 
        <fill>1</fill>
        <outline>1</outline>
      </PolyStyle>
    </Style>

    <!-- Thẻ chứa dữ liệu hình học (Geometry Placemark) -->
    <Placemark>
      <name>Khu Vuc Thu Thiem Mau</name>
      <!-- Gọi lại kiểu dáng đã định nghĩa ở trên -->
      <styleUrl>#DinhDang_VungDo</styleUrl> 
      <Polygon>
        <outerBoundaryIs>
          <LinearRing>
            <coordinates>
              106.71000,10.77000,0
              106.72000,10.77000,0
              106.72000,10.78000,0
              106.71000,10.78000,0
              106.71000,10.77000,0
            </coordinates>
          </LinearRing>
        </outerBoundaryIs>
      </Polygon>
    </Placemark>
    
  </Document>
</kml>